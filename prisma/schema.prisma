generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Couple {
  id         String   @id @default(cuid())
  inviteCode String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users User[]
  dates Date[]

  @@map("couples")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  coupleId     String?
  couple       Couple?  @relation(fields: [coupleId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

enum DateStatus {
  PENDING
  ACCEPTED
  COMPLETED
}

model Date {
  id        String     @id @default(cuid())
  title     String?
  places    String[]
  foods     String[]
  dateTime  DateTime
  status    DateStatus @default(ACCEPTED)
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  coupleId  String?
  couple    Couple?    @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  photos Photo[]

  @@index([coupleId])
  @@index([dateTime(sort: Desc)])
  @@map("dates")
}

model Photo {
  id        String   @id @default(cuid())
  dateId    String
  imageUrl  String
  caption   String?
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  date Date @relation(fields: [dateId], references: [id], onDelete: Cascade)

  @@index([dateId])
  @@map("photos")
}
